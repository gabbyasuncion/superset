# -----------------------------------------------------------------------
# Copy this file to .env-local and fill in your secret values.
# docker-compose loads .env-local as an optional override after docker/.env.
# -----------------------------------------------------------------------

# Automations Admin API secrets (required)
DEVIN_API_KEY=your-devin-api-key
DEVIN_ORG_ID=your-devin-org-id
JIRA_API_EMAIL=your-email@example.com
JIRA_API_TOKEN=your-jira-api-token
JIRA_ASSIGNEE_ACCOUNT_ID=your-jira-account-id
