# Automations Admin API - Environment Variables
# Copy this file to .env and fill in the values.
#
# Required for Devin API client
DEVIN_API_KEY=
DEVIN_ORG_ID=

# Required for Jira API client
JIRA_API_EMAIL=
JIRA_API_TOKEN=

# Optional - defaults shown
AUTOMATIONS_NUM_BUGS=5
JIRA_PROJECT_KEY=SUP
JIRA_ASSIGNEE_ACCOUNT_ID=
